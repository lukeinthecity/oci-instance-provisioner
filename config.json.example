{
  "_comment": "Copy this file to 'config.json' (same folder) and replace every value. config.json is git-ignored and never published. See README.md for how to obtain each OCID.",

  "CompartmentId": "ocid1.tenancy.oc1..REPLACE_ME",
  "SubnetId": "ocid1.subnet.oc1.REGION.REPLACE_ME",
  "ImageId": "ocid1.image.oc1.REGION.REPLACE_ME",
  "_availabilityDomain": "Use the FULL name incl. the tenancy prefix (the part before the colon is assigned per-tenancy, NOT derivable). Get it with: oci iam availability-domain list --compartment-id <tenancy-ocid> --query \"data[].name\" --raw-output . YOUR CHOICE: a single string polls ONE AD; a JSON array sweeps SEVERAL each cycle, e.g. [\"abCD:US-ASHBURN-AD-1\", \"abCD:US-ASHBURN-AD-2\", \"abCD:US-ASHBURN-AD-3\"]",
  "AvailabilityDomain": "REPLACE_ME-example:US-ASHBURN-AD-1",
  "SshKeyPath": "C:\\Users\\REPLACE_ME\\.ssh\\id_ed25519.pub",
  "NtfyTopic": "REPLACE_ME-pick-a-unique-string",

  "_region": "STRONGLY recommended. Must match the region of your Subnet/Image/AD (e.g. us-ashburn-1). If blank, the CLI uses the region from ~/.oci/config, which can silently mismatch and loop forever on a 404.",
  "Region": "us-ashburn-1",

  "_optional": "Everything below is optional. Defaults shown reflect the full Always Free ARM allocation (4 OCPU / 24 GB). Remove any line to accept its default.",

  "Shape": "VM.Standard.A1.Flex",
  "Ocpus": 4,
  "MemoryInGBs": 24,
  "DisplayName": "oci-free-arm-instance",
  "AssignPublicIp": true,

  "_antiIdleKeepAlive": "On by default. Bakes a cloud-init cron job into the launch (runs on the instance itself, every 6h) that briefly burns one core so Oracle's idle-instance reclamation never sees a genuinely idle box. Set to false to opt out.",
  "AntiIdleKeepAlive": true,

  "_ntfyServer": "Optional ntfy base URL. Defaults to https://ntfy.sh. Point this at your own server to self-host notifications.",
  "NtfyServer": "https://ntfy.sh",

  "BaseDelaySeconds": 60,
  "JitterSeconds": 30,

  "_ociCliConfigPath": "ONLY needed when running as a SYSTEM Scheduled Task: absolute path to the ~/.oci/config you created with 'oci setup config'. Leave blank for interactive/user runs. e.g. C:\\\\Users\\\\you\\\\.oci\\\\config",
  "OciCliConfigPath": "",

  "_logAndMarker": "Leave blank to use defaults next to the script (provisioner.log / provisioner.success).",
  "LogPath": "",
  "SuccessMarkerPath": ""
}
